# Google Maps API Key
# Get this from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HubSpot API Key (for backend server only)
# Get this from: https://app.hubspot.com/l/api-key/
# Make sure this key has access to your custom Locations object
VITE_HUBSPOT_API_KEY=your_hubspot_pat_token_here

# HubSpot Custom Object Type ID
# Get from: https://app.hubspot.com/object-type-settings/YOUR_PORTAL_ID/object/YOUR_OBJECT_ID
VITE_HUBSPOT_OBJECT_TYPE=2-16842375

# Backend API URL (for development)
# Default: http://localhost:3000
VITE_API_URL=http://localhost:3000
